{
  "name": "actual-rest-api",
  "version": "1.0.0",
  "description": "REST API wrapper para Actual Budget",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@actual-app/api": "latest",
    "@hono/node-server": "^1.19.9",
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
